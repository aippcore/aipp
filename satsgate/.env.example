# Copy this file to .env and adjust values
# If you're using docker-compose + Caddy, also set SATSGATE_HOSTNAME below.

# Secret used to sign the "macaroon" (our token). Change in production.
SATSGATE_MACAROON_SECRET=dev-change-me

# Demo price for /v1/tickets (in sats)
SATSGATE_PRICE_SATS=10

# Token TTL (seconds)
SATSGATE_TOKEN_TTL_SECONDS=600

# Wallet backend:
# - mock   => simulated wallet (recommended for local testing)
# - lnaddr => generates invoices via your Lightning Address (LNURL-pay)
SATSGATE_WALLET_MODE=mock

# Required if WALLET_MODE=lnaddr
# Example: user@domain
SATSGATE_LIGHTNING_ADDRESS=

# DB (SQLite). If empty, uses ./satsgate.sqlite3
SATSGATE_DB_PATH=

# Rate limit (simple in-memory)
SATSGATE_RL_ENABLED=1
SATSGATE_RL_WINDOW_SECONDS=60
SATSGATE_RL_MAX_ANON=60
SATSGATE_RL_MAX_AUTH=600

# Operator/admin token.
# When set, enables /v1/admin/* endpoints (protected via X-Admin-Token header).
SATSGATE_ADMIN_TOKEN=

# Hostname used by Caddy (docker-compose). Example: api.satsgate.org
SATSGATE_HOSTNAME=

# Dev mode enables /dev/* endpoints
SATSGATE_DEV_MODE=1
